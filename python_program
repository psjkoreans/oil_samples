# [모듈 3] 분석 및 시각화 파이프라인 (Analysis Pipeline)
# ==========================================

def run_analysis():
    # 1. 입력 제어
    try:
        new_mileage = float(input("신규 샘플의 주행거리(km)를 입력하세요: "))
        print("\n분석할 엔진 오일 이미지를 업로드하세요:")
        uploaded = files.upload()
        if not uploaded: return None
        image_bytes = uploaded[list(uploaded.keys())[0]]
    except Exception as e:
        print(f"시스템 오류: {e}")
        return None

    # 2. 데이터 병합 및 Lab 변환
    new_r, new_g, new_b = extract_rgb_from_image(image_bytes)
    
    # 주의: HISTORICAL_SEED_DATA는 글로벌에 선언되어 있어야 함
    payload = [dict(item, isNew=False) for item in HISTORICAL_SEED_DATA]
    payload.append({"mileage": new_mileage, "r": new_r, "g": new_g, "b": new_b, "isNew": True})
    payload.sort(key=lambda x: x['mileage'])

    for item in payload:
        item.update(rgb_to_lab(item['r'], item['g'], item['b']))

    # 3. 기준점(Anchor) 산출 (Z-Score 통계량 삭제됨)
    lab_ref = rgb_to_lab(174, 184, 175)
    L_0, b_0 = lab_ref['L'], lab_ref['b']

    # 4. Two-Stage 알고리즘 적용 (이상치 탐지 제거)
    max_b, peak_L, peak_DI, is_stage_2 = b_0, L_0, 0.0, False
    evaluated_data = []

    for row in payload:
        current_b_dist = abs(row['b'] - b_0)
        
        # 4.1 Stage 판별 (Oxidation vs Sludge)
        if not is_stage_2:
            if row['b'] > max_b: 
                max_b, peak_L, peak_DI = row['b'], row['L'], current_b_dist
            if row['b'] < max_b - 10.0: 
                is_stage_2 = True

        base_di = current_b_dist if not is_stage_2 else (peak_DI + 0.7 * max(0, peak_L - row['L']) + 0.3 * abs(max_b - row['b']))
        
        # 4.2 최종 지표 및 상태 할당 (단일 DI 사용)
        row['DI'] = base_di
        is_sat = row['L'] < 30.0

        if is_sat or base_di >= 115.0: ph, cl = 'Phase 5: 즉시 교체 필요', '#000000'
        elif base_di >= 90.0: ph, cl = 'Phase 4: 심화 열화', '#8B0000'
        elif base_di >= 60.0: ph, cl = 'Phase 3: 진행 중', '#FF0000'
        elif base_di >= 30.0: ph, cl = 'Phase 2: 열화 시작', '#FFA500'
        else: ph, cl = 'Phase 1: 신유/정상', '#FFD700'

        row.update({
            'phase': ph, 
            'color': cl, 
            'needsReplacement': is_sat or base_di >= 115.0
        })
        evaluated_data.append(row)

    # 5. 시각화 모듈 및 3차 다항 회귀 (2x2 복구)
    mileages = [d['mileage'] for d in evaluated_data]
    L_vals = [d['L'] for d in evaluated_data]
    a_vals = [d['a'] for d in evaluated_data]
    b_vals = [d['b'] for d in evaluated_data]
    di_vals = [d['DI'] for d in evaluated_data] # [수정됨] 단일 DI 배열 사용
    
    colors = [d['color'] for d in evaluated_data]
    sizes = [150 if d['isNew'] else 50 for d in evaluated_data]
    
    x_arr = np.array(mileages)
    y_arr = np.array(di_vals)
    has_enough_data = len(x_arr) >= 4

    # 3차 회귀 수용
    if has_enough_data:
        coeffs = np.polyfit(x_arr, y_arr, 3)
        poly_eq = np.poly1d(coeffs)
        x_trend = np.linspace(min(x_arr), max(x_arr), 100)
        y_trend = poly_eq(x_trend)
        y_pred = poly_eq(x_arr)
        r2 = r2_score(y_arr, y_pred)

    fig, axs = plt.subplots(2, 2, figsize=(14, 10))
    fig.suptitle('Engine Oil L*a*b* Degradation & Predictive Regression', fontsize=16)

    def plot_subplot(ax, x, y, title, ylabel, c, s, is_di_graph=False):
        ax.plot(x, y, color='gray', zorder=1, alpha=0.5, linestyle='-')
        ax.scatter(x, y, c=c, s=s, zorder=2, edgecolors='black', linewidths=1.5)
        
        if is_di_graph and has_enough_data:
            ax.plot(x_trend, y_trend, color='blue', zorder=0, linestyle='--', linewidth=2.5,
                    label=f'Poly Regression 3rd (R²={r2:.2f})')
            ax.legend(loc='upper left')
            
        ax.set_title(title)
        ax.set_xlabel('Mileage (km)')
        ax.set_ylabel(ylabel)
        ax.grid(True, linestyle='--', alpha=0.6)

    plot_subplot(axs[0, 0], mileages, L_vals, 'CIE L* (Lightness Decay)', 'L* Value', colors, sizes)
    plot_subplot(axs[0, 1], mileages, a_vals, 'CIE a* (Observation Only)', 'a* Value', colors, sizes)
    plot_subplot(axs[1, 0], mileages, b_vals, 'CIE b* (Oxidation Peak Tracked)', 'b* Value', colors, sizes)
    plot_subplot(axs[1, 1], mileages, di_vals, 'Degradation Index (2-Stage Algorithm)', 'DI Score', colors, sizes, is_di_graph=True)
    
    plt.tight_layout()
    plt.show()

    # 6. 진단 리포트 출력
    new_d = next((d for d in evaluated_data if d.get('isNew') == True), None)
    historical_data = [d for d in evaluated_data if d.get('isNew') == False]

    if not new_d: 
        return

    print(f"\n{'='*70}\n [인공지능 엔진 오일 분석 리포트] 측정된 주행거리: {new_d['mileage']:,.0f} km\n{'='*70}")
    print(f"▶ 현재 오일 상태 판별: {new_d['phase']} (누적 오염도: {new_d['DI']:.2f})")
    
    if new_d['needsReplacement']: 
        print("⚠️ 시스템 경고: 오염도가 안전 기준을 초과했습니다. 즉각적인 교체가 필요합니다.")

    if historical_data:
        nearest = min(historical_data, key=lambda x: abs(x['mileage'] - new_d['mileage']))
        diff_di = new_d['DI'] - nearest['DI']
        
        print(f"\n[과거 측정 기록과의 비교 분석]\n▶ 참조 기록({nearest['mileage']:,.0f}km) 대비 분석 결과:")
        
        if diff_di < -10.0: 
            print(f" 🟢 오일 상태가 예상보다 훨씬 깨끗합니다 ({diff_di:.2f}).")
            print(f"    최근 오일 보충 또는 교환이 강력히 의심됩니다.")
        elif diff_di > 10.0: 
            print(f" 🔴 오염도가 참조 기록 대비 비정상적으로 높습니다 (증가폭: +{diff_di:.2f}).")
            print(f"    엔진 내 마모나 가스 유입 가능성을 점검하십시오.")
        else: 
            print(f" 🟡 오염도 변동이 정상 범위 내에 있습니다 ({diff_di:.2f}).")
            print(f"    현재 주행거리에서 기대되는 표준 열화 궤적을 안정적으로 따르고 있습니다.")
        print("="*70)

# 메인 프로세스 트리거
run_analysis()
