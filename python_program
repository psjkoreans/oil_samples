# [모듈 2] 수학적 모델 및 전처리 (Mathematical Models)
# ==========================================

def rgb_to_lab(r, g, b):
    """sRGB를 비선형 CIE L*a*b* 색공간으로 변환 (D65 표준)"""
    r_l, g_l, b_l = r / 255.0, g / 255.0, b / 255.0
    r_l = ((r_l + 0.055) / 1.055) ** 2.4 if r_l > 0.04045 else r_l / 12.92
    g_l = ((g_l + 0.055) / 1.055) ** 2.4 if g_l > 0.04045 else g_l / 12.92
    b_l = ((b_l + 0.055) / 1.055) ** 2.4 if b_l > 0.04045 else b_l / 12.92

    x = (r_l * 0.4124 + g_l * 0.3576 + b_l * 0.1805) * 100
    y = (r_l * 0.2126 + g_l * 0.7152 + b_l * 0.0722) * 100
    z = (r_l * 0.0193 + g_l * 0.1192 + b_l * 0.9505) * 100

    x, y, z = x / 95.047, y / 100.000, z / 108.883
    x = x ** (1/3) if x > 0.008856 else (7.787 * x) + (16/116)
    y = y ** (1/3) if y > 0.008856 else (7.787 * y) + (16/116)
    z = z ** (1/3) if z > 0.008856 else (7.787 * z) + (16/116)
    return {'L': (116 * y) - 16, 'a': 500 * (x - y), 'b': 200 * (y - z)}

def extract_rgb_from_image(image_bytes):
    """이미지 중앙 50% ROI 픽셀 평균 RGB 추출"""
    img = Image.open(io.BytesIO(image_bytes)).convert('RGB')
    w, h = img.size
    start_x, start_y = int(w * 0.25), int(h * 0.25)
    roi_w, roi_h = int(w * 0.5), int(h * 0.5)
    roi = img.crop((start_x, start_y, start_x + roi_w, start_y + roi_h))
    np_roi = np.array(roi)
    r, g, b = np_roi.mean(axis=(0, 1))
    return int(round(r)), int(round(g)), int(round(b))


